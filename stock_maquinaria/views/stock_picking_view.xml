<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_picking_tree_all" model="ir.actions.act_window">
        <field name="name">Transferencias Maquinaria</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.picking</field>
        <field name="view_id" ref="stock.view_picking_internal_search"/>
        <field name="view_mode">tree,kanban,form,calendar</field>
        <field name="context">{'default_tipo':'maquinaria'}</field>
        <field name="domain">[('tipo','=','maquinaria')]</field>
    </record>

    <record id="view_picking_form" model="ir.ui.view">
    	<field name="name">stock.picking.form</field>
    	<field name="model">stock.picking</field>
    	<field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <field name="move_type" position="after">
                <field name="tipo"/>
            </field>
        </field>
    </record>

    <menuitem id="menu_all_picking_maq" name="Transferencias maquinaria" parent="stock.menu_stock_warehouse_mgmt" sequence="5" action="action_picking_tree_all" groups="stock.group_stock_manager,stock.group_stock_user"/>
</odoo>